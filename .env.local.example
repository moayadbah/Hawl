# Copy this file to .env.local (already gitignored) and fill in real values from
# your Supabase project's Settings → API Keys page.

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Secret key (starts with sb_secret_..., or the legacy service_role JWT on older
# projects) — server-only, NEVER expose this to client code or commit it.
SUPABASE_SECRET_KEY=
